# --- Runtime ---
ENVIRONMENT=development              # development | staging | production

# --- Mongo ---
# Switch between local Docker and Atlas by changing MONGO_TARGET.
# MONGO_TARGET=local  → uses MONGO_URL_LOCAL (Docker Compose)
# MONGO_TARGET=atlas  → uses MONGO_URL_ATLAS (MongoDB Atlas)
MONGO_TARGET=local
MONGO_URL_LOCAL=mongodb://localhost:27017
MONGO_URL_ATLAS=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?appName=<app>
MONGO_DB_NAME=dishmatch

# --- JWT ---
# In production this MUST be a random >=32 char string. The app refuses to boot otherwise.
JWT_SECRET=replace-with-a-long-random-string-please
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30

# --- Third-party ---
GOOGLE_PLACES_API_KEY=
EXPO_PUSH_URL=https://exp.host/--/api/v2/push/send

# --- HTTP / CORS ---
# In production set explicit origins (no wildcard) and explicit hosts.
CORS_ORIGINS=["*"]
ALLOWED_HOSTS=["*"]
MAX_REQUEST_BODY_BYTES=1000000

# --- Rate limits (slowapi syntax: N/period) ---
RATE_LIMIT_ENABLED=true
RATE_LIMIT_DEFAULT=100/minute
RATE_LIMIT_SIGNUP=5/minute
RATE_LIMIT_LOGIN=10/minute
RATE_LIMIT_REFRESH=30/minute
RATE_LIMIT_SESSION_CREATE=10/minute
RATE_LIMIT_SESSION_JOIN=20/minute
RATE_LIMIT_SWIPE=60/minute
RATE_LIMIT_RESTAURANTS=20/minute
RATE_LIMIT_PUSH_TOKEN=10/minute

# --- Domain limits ---
MAX_SESSION_MEMBERS=12
